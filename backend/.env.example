PORT=5000
NODE_ENV=development
TRUST_PROXY=0

# MySQL (Sequelize)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=curenet
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
AUTH_ALLOW_UNVERIFIED_LOGIN=true

# App URLs
APP_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
UPLOADS_DIR=./uploads

# First admin (for npm run create-admin)
# ADMIN_EMAIL=admin@curenet.local
# ADMIN_PASSWORD=change-me
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=User

# SMTP email transport
# Local development can point to Mailpit/MailHog on localhost:1025.
# For real delivery, replace these with Brevo or another SMTP provider.
# These settings are used by both email verification and password reset mail.
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM=CureNet <no-reply@curenet.local>
# MAIL_USER=
# MAIL_PASSWORD=

# Reminder worker
REMINDER_WORKER_POLL_MS=60000
REMINDER_WORKER_BATCH_SIZE=25
REMINDER_MISSED_GRACE_MINUTES=120
REMINDER_REPLENISH_HORIZON_DAYS=7


SHOW_SWAGGER=false