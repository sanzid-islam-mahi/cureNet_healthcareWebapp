# Public app origin used by the backend for cookies, links, and CORS.
# For local LAN testing, replace localhost with your PC's LAN IP or hostname.
APP_BASE_URL=https://localhost
CORS_ORIGIN=https://localhost

# Database
DB_NAME=curenet
DB_USER=curenet
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-password

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=curenet_auth
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_ALLOW_UNVERIFIED_LOGIN=false
TRUST_PROXY=1

# Mail transport
# For local-only deploy testing without a provider, set these to your SMTP server.
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_FROM=CureNet <no-reply@curenet.local>
MAIL_USER=
MAIL_PASSWORD=

# Reminder worker
REMINDER_WORKER_POLL_MS=60000
REMINDER_WORKER_BATCH_SIZE=25
REMINDER_MISSED_GRACE_MINUTES=120
REMINDER_REPLENISH_HORIZON_DAYS=7
